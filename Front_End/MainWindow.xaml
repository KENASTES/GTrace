<Window x:Class="Front_End.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GTrace - Garber to G-Code"
                Height="450"
                Width="800"
                Background="#F0F0F0">

        <Grid Margin="15">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                                Margin="0,0,15,0">
                        <TextBlock Text="GTRACE"
                                        FontSize="28"
                                        FontWeight="Black"
                                        Foreground="#333"
                                        Margin="0,0,0,5"/>
                        <TextBlock Text="Garber to G-Code Converter"
                                        FontSize="14"
                                        Foreground="#666"
                                        Margin="0,0,0,20"/>

                        <TextBlock Text="Input File"
                                        FontWeight="SemiBold"
                                        Margin="0,0,0,5"/>
                        <Button Name="SelectFileButton"
                                        Content="Browse a Garber File"
                                        Height="35"
                                        Click="SelectFileButtonClick"/>
                        <TextBlock Name="SelectedFileText"
                                        Text="No file selected"
                                        FontSize="11"
                                        Foreground="Gray"
                                        TextWrapping="Wrap"
                                        Margin="0,5,0,15"/>

                        <TextBlock Text="G-Code Settings"
                                        FontWeight="SemiBold"
                                        Margin="0,0,0,5"/>

                        <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Feed Rate (mm/min):"
                                                VerticalAlignment="Center"/>
                                <TextBox Name="FeedRateInput"
                                                Grid.Column="1"
                                                Text="800"
                                                Height="25"
                                                VerticalContentAlignment="Center"
                                                Padding="5,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Laser Power (PWM):"
                                                VerticalAlignment="Center"/>
                                <TextBox Name="LaserPowerInput"
                                                Grid.Column="1"
                                                Text="255"
                                                Height="25"
                                                VerticalContentAlignment="Center"
                                                Padding="5,0"/>
                        </Grid>

                        <Button Name="GenerateButton"
                                        Content="GENERATE G-CODE"
                                        Height="45"
                                        Background="#007ACC"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="14"/>
                </StackPanel>

                <GroupBox Grid.Column="1"
                                Header="Process Console"
                                FontWeight="Bold">
                        <TextBox Name="ConsoleLog"
                                 IsReadOnly="True"
                                 Background="#1E1E1E"
                                 Foreground="#4CAF50"
                                 FontFamily="Consolas"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="> Gtrace Core Engine Initialized...&#x0A;> Waiting for input..."
                                 Padding="10"/>
                </GroupBox>
        </Grid>
</Window>