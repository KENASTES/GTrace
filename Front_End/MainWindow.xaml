<Window x:Class="Front_End.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GTrace - Gerber to G-Code"
        Height="720"
        Width="1280"
        Background="#F0F0F0">

        <Window.Resources>
                <Style TargetType="CheckBox"
                       x:Key="ModernCheckBox">
                        <Setter Property="Foreground"
                                Value="#333"/>
                        <Setter Property="FontSize"
                                Value="13"/>
                        <Setter Property="FontWeight"
                                Value="SemiBold"/>
                        <Setter Property="Margin"
                                Value="0,5,0,15"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                        <Border x:Name="Border"
                                                                Width="18"
                                                                Height="18"
                                                                Background="White"
                                                                BorderBrush="#BDBDBD"
                                                                BorderThickness="1.5"
                                                                CornerRadius="4"
                                                                VerticalAlignment="Center">
                                                                <Path x:Name="CheckMark"
                                                                      Data="M 4,9 L 8,13 L 14,5"
                                                                      Stroke="White"
                                                                      StrokeThickness="2.5"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      StrokeLineJoin="Round"
                                                                      Visibility="Collapsed"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ContentPresenter Margin="10,0,0,0"
                                                                          VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                                <Setter TargetName="Border"
                                                                        Property="Background"
                                                                        Value="#007ACC"/>
                                                                <Setter TargetName="Border"
                                                                        Property="BorderBrush"
                                                                        Value="#007ACC"/>
                                                                <Setter TargetName="CheckMark"
                                                                        Property="Visibility"
                                                                        Value="Visible"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                                <Setter TargetName="Border"
                                                                        Property="BorderBrush"
                                                                        Value="#007ACC"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Window.Resources>

        <Grid Margin="15">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,15,0">
                        <TextBlock Text="GTRACE"
                                   FontSize="28"
                                   FontWeight="Black"
                                   Foreground="#333"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="CNC CAM &amp; G-Code Generator"
                                   FontSize="14"
                                   Foreground="#666"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Operation Mode"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <Border BorderBrush="#DDD"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="10"
                                Margin="0,0,0,20"
                                Background="White">
                                <StackPanel>
                                        <RadioButton Name="rbPcbMode"
                                                     Content="Gerber Converter (PCB Etching Mode)"
                                                     IsChecked="True"
                                                     Checked="Mode_Checked"
                                                     FontSize="13"
                                                     FontWeight="SemiBold"
                                                     Margin="0,0,0,10"/>
                                        <RadioButton Name="rbEngraveMode"
                                                     Content="Image Converter (Engraving Mode)"
                                                     Checked="Mode_Checked"
                                                     FontSize="13"
                                                     FontWeight="SemiBold"/>
                                </StackPanel>
                        </Border>

                        <StackPanel Name="PanelPcbMode">
                                <TextBlock Text="Input File"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5"/>
                                <Button Name="SelectFileButton"
                                        Content="Browse a Gerber File"
                                        Height="35"
                                        Click="SelectFileButtonClick"/>
                                <TextBlock Name="SelectedFileText"
                                           Text="No file selected"
                                           FontSize="11"
                                           Foreground="Gray"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,15"/>

                                <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Border Width (mm):"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Name="IsolationWidthInput"
                                                 Grid.Column="1"
                                                 Text="0.60"
                                                 Height="25"
                                                 VerticalContentAlignment="Center"
                                                 Padding="5,0"/>
                                </Grid>
                                <CheckBox Name="chkMirrorX"
                                          Content="Mirror X-Axis (Bottom Layer)"
                                          Style="{StaticResource ModernCheckBox}"/>
                        </StackPanel>

                        <StackPanel Name="PanelEngraveMode"
                                        Visibility="Collapsed">
                                <TextBlock Text="Input File"
                                                FontWeight="SemiBold"
                                                Margin="0,0,0,5"/>
                                <Button Name="SelectImageButton"
                                                Content="Browse PNG / DXF"
                                                Height="35"
                                                Click="SelectImageButtonClick"
                                                Background="#E0E0E0"
                                                Foreground="Black"/>
                                <TextBlock Name="SelectedImageText"
                                                Text="No image selected"
                                                FontSize="11"
                                                Foreground="Gray"
                                                TextWrapping="Wrap"
                                                Margin="0,5,0,15"/>

                                <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Target Width (mm):"
                                                        VerticalAlignment="Center"/>
                                        <TextBox Name="ImageWidthInput"
                                                        Grid.Column="1"
                                                        Text="50.0"
                                                        Height="25"
                                                        VerticalContentAlignment="Center"
                                                        Padding="5,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Target Height (mm):"
                                                        VerticalAlignment="Center"/>
                                        <TextBox Name="ImageHeightInput"
                                                        Grid.Column="1"
                                                        Text="50.0"
                                                        Height="25"
                                                        VerticalContentAlignment="Center"
                                                        Padding="5,0"/>
                                </Grid>

                                <CheckBox Name="chkInvertColors"
                                                Content="Invert Colors (Dark as Copper)"
                                                Style="{StaticResource ModernCheckBox}"/>
                        </StackPanel>

                        <TextBlock Text="General Settings"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,5"/>
                        <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Feed Rate (mm/min):"
                                           VerticalAlignment="Center"/>
                                <TextBox Name="FeedRateInput"
                                         Grid.Column="1"
                                         Text="800"
                                         Height="25"
                                         VerticalContentAlignment="Center"
                                         Padding="5,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Laser Power (S-Value):"
                                           VerticalAlignment="Center"/>
                                <TextBox Name="LaserPowerInput"
                                         Grid.Column="1"
                                         Text="215"
                                         Height="25"
                                         VerticalContentAlignment="Center"
                                         Padding="5,0"/>
                        </Grid>

                        <TextBlock Text="Output G-Code File"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Name="OutputFilePathText"
                                         Text="No path selected"
                                         IsReadOnly="True"
                                         Background="#E0E0E0"
                                         Padding="5"/>
                                <Button Name="SaveFileButton"
                                        Grid.Column="1"
                                        Content="Save As..."
                                        Width="80"
                                        Margin="10,0,0,0"
                                        Click="SaveFileButtonClick"/>
                        </Grid>

                        <Button Name="GenerateButton"
                                Content="GENERATE G-CODE"
                                Height="45"
                                Background="#007ACC"
                                Foreground="White"
                                FontWeight="Bold"
                                FontSize="14"/>
                </StackPanel>

                <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="160"/>
                        </Grid.RowDefinitions>

                        <GroupBox Grid.Row="0"
                                  Header="PCB Viewport (Gerber &amp; G-Code Preview)"
                                  FontWeight="Bold"
                                  Margin="0,0,0,10">
                                <Grid Background="#1E1E1E"
                                      Name="ViewportContainer"
                                      ClipToBounds="True"
                                      MouseWheel="Viewport_MouseWheel"
                                      MouseDown="Viewport_MouseDown"
                                      MouseMove="Viewport_MouseMove"
                                      MouseUp="Viewport_MouseUp">

                                        <Canvas Name="PreviewCanvas">
                                                <Canvas.RenderTransform>
                                                        <TransformGroup>
                                                                <ScaleTransform x:Name="CanvasScale"
                                                                                ScaleX="5"
                                                                                ScaleY="-5"/>
                                                                <TranslateTransform x:Name="CanvasTranslate"
                                                                                    X="100"
                                                                                    Y="400"/>
                                                        </TransformGroup>
                                                </Canvas.RenderTransform>
                                        </Canvas>

                                        <Border VerticalAlignment="Bottom"
                                                HorizontalAlignment="Left"
                                                Margin="10"
                                                Background="#80000000"
                                                Padding="5">
                                                <StackPanel>
                                                        <TextBlock Name="TxtCursorPos"
                                                                   Text="X: 0.000, Y: 0.000 mm"
                                                                   Foreground="#FFF"
                                                                   FontFamily="Consolas"
                                                                   FontSize="11"/>
                                                        <TextBlock Name="TxtBoardBounds"
                                                                   Text="Bounds: Calculating..."
                                                                   Foreground="#007ACC"
                                                                   FontWeight="Bold"
                                                                   FontFamily="Consolas"
                                                                   FontSize="11"
                                                                   Margin="0,3,0,0"/>
                                                </StackPanel>
                                        </Border>

                                        <Button Content="Fit to View"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="10"
                                                Width="80"
                                                Height="25"
                                                Click="BtnFitToView_Click"
                                                Background="#333"
                                                Foreground="White"
                                                BorderBrush="#555"/>
                                </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1"
                                  Header="Process Console"
                                  FontWeight="Bold">
                                <TextBox Name="ConsoleLog"
                                         IsReadOnly="True"
                                         Background="#1E1E1E"
                                         Foreground="#4CAF50"
                                         FontFamily="Consolas"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="> Gtrace Core Engine Initialized...&#x0A;> Waiting for input..."
                                         Padding="10"/>
                        </GroupBox>
                </Grid>
        </Grid>
</Window>
